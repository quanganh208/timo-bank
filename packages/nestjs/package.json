{
  "name": "@timo-bank/nestjs",
  "version": "0.1.4",
  "description": "Unofficial Timo Bank SDK - NestJS module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "timo",
    "bank",
    "vietnam",
    "banking",
    "sdk",
    "nestjs",
    "module"
  ],
  "author": "quanganh208",
  "license": "MIT",
  "homepage": "https://github.com/quanganh208/timo-bank#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quanganh208/timo-bank.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/quanganh208/timo-bank/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@timo-bank/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^5.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
